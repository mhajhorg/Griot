# Server
PORT=3001

# Arc / blockchain
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
ARC_USDC_ADDRESS=0x3600000000000000000000000000000000000000
GRIOT_REGISTRY_ADDRESS=0xfa5546B28B8646F8075672e294dAA2F013636F4f

# Wallets used for on-chain calls (never commit real keys)
DEPLOYER_PRIVATE_KEY=



# Supabase (falls back to in-memory store if unset)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# BlockRun (agent LLM inference — paid via x402 from this wallet, not an API key)
BLOCKRUN_WALLET_KEY=
BLOCKRUN_MODEL=

# Set to true for local dev — uses Base Sepolia test funds instead of real USDC
#BLOCKRUN_TESTNET=true

# Circle Developer-Controlled Wallets
CIRCLE_API_KEY=

CIRCLE_ENTITY_SECRET=
CIRCLE_WALLET_SET_ID=

ENABLE_ACTIVITY_BOT=
ACTIVITY_BOT_INTERVAL_MINUTES=
ACTIVITY_BOT_BUDGET_USDC=