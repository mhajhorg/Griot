# Supabase (falls back to in-memory store if unset)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# BlockRun (agent LLM inference — paid via x402 from this wallet, not an API key)
BLOCKRUN_WALLET_KEY=
BLOCKRUN_API_URL=https://api.blockrun.ai/v1
BLOCKRUN_MODEL=nvidia/gpt-oss-120b
